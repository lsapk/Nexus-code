{
  "expo": {
    "name": "Nexus Code",
    "slug": "nexus-code",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexus.code"
    },
    "android": {
      "package": "com.nexus.code"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-sqlite",
        {
          "enableVisualizer": true
        }
      ]
    ]
  }
}
